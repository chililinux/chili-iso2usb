export LANGUAGE="${LANGUAGE:-pt_BR}"
export TEXTDOMAINDIR="${TEXTDOMAINDIR:-/usr/share/locale}"
export TEXTDOMAIN="chili-iso2usb"

declare APP="${0##*/}"
declare _VERSION_="1.06.12-20260612"
declare APPDESC="$APP - Utilitário para gravar ISO"
declare DEPENDENCIES=(yad zenity dd grep awk lsblk sync gettext fdisk)

check_deps() {
	local errorFound=false
	local missing=()

	for f in "${DEPENDENCIES[@]}"; do
		if ! command -v "$f" &>/dev/null; then
			missing+=("$f")
			errorFound=true
			printf "$(gettext "ERRO: não encontrei o comando '%s'")\n" "$f" >&2
		fi
	done
	if $errorFound; then
		echo "$(gettext "---IMPOSSÍVEL CONTINUAR---")" >&2
		echo "$(gettext "Esse script necessita dos comandos listados acima")" >&2
		echo "$(gettext "Instale-os e/ou verifique se estão no seu \$PATH")" >&2
		exit 1
	fi
}

yad_message() {
	local msg="$1"
	local txt="<b><big>$msg</big></b>"
	yad "${comargs[@]}" --image=gtk-dialog-info --text="$txt" --button="$(gettext "Fechar")":1
}

sh_initvars() {
	declare -x COMARGS
	: "${ARRAY_DSK_DEVICES=()}"
	: "${ARRAY_DSK_DISKS=()}"
	: "${ARRAY_DSK_SIZE=()}"
	: "${ARRAY_DSK_MODEL=()}"
	: "${ARRAY_DSK_TRAN=()}"
	: "${ARRAY_DSK_LABEL=()}"
	: sep='\xe2\x94\x82'

	# Detecta o HOME do usuário real para evitar o do root
	local real_user="${SUDO_USER:-$USER}"
	local real_home
	real_home=$(eval echo "~$real_user")

	if [[ -d "$real_home/Downloads" ]]; then
		ISO_START_DIR="$real_home/Downloads/"
	else
		ISO_START_DIR="$real_home/"
	fi

	comargs=(
		--title="${APP} - v${_VERSION_}"
		--center
		--width=450
		--height=250
		--text-align=center
		--buttons-layout=center
		--borders=10
		--image=/usr/share/pixmaps/pendrive.png
	)

	COMARGS=$(printf "%q " "${comargs[@]}")
	MSG=(
		[0]="$(gettext 'Selecione a ISO para copiar')"
		[1]="$(gettext 'Sair') $app"
		[2]="N°"
		[3]="$(gettext 'Nome')"
		[4]="$(gettext 'Tamanho em GB')"
		[5]="$(gettext 'Selecione o seu USB drive')"
		[6]="$(gettext 'Atenção tamanho muito grande')"
		[7]="$(gettext 'ATENÇÃO !!!')"
		[8]="$(gettext 'Poderia ser um disco rígido externo. \nContinuar ?')"
		[9]="$(gettext 'Problema na ferramenta. Contactar o autor.')"
		[10]="$(gettext 'Progresso:')"
		[11]="$(gettext 'Copiar de')"
		[12]="$(gettext 'Você já pode remover o seu USB drive.')"
		[13]="$(gettext 'Fim da copia')"
		[14]="$(gettext 'Operação cancelada pelo usuário')"
		[15]="$(gettext 'Cancelado')"
	)
}

sh_disk_info() {
	unset ARRAY_DSK_{DISKS,DEVICES,SIZE,TRAN,MODEL,LABEL}
	local {NAME,PATH,SIZE,TRAN,MODEL,LABEL}_

	while read -r line; do
		eval "${line//=/_=}"
		ARRAY_DSK_DISKS+=("$NAME_")
		ARRAY_DSK_DEVICES+=("$PATH_")
		ARRAY_DSK_SIZE+=("$SIZE_")
		ARRAY_DSK_TRAN+=("${TRAN_:-blk}")
		ARRAY_DSK_MODEL+=("${MODEL_:-unknown}")
		ARRAY_DSK_LABEL+=("${LABEL_:-none}")
	done < <(lsblk -Pao TYPE,NAME,PATH,SIZE,TRAN,MODEL,LABEL | grep usb)
}

sh_choosedisk() {
	sh_disk_info
	local i
	local nc=0
	USBDSK=()
	export USBDSK

	for blkdsk in "${ARRAY_DSK_DEVICES[@]}"; do
		USBDSK+="$blkdsk ${ARRAY_DSK_TRAN[$nc]} ${ARRAY_DSK_SIZE[$nc]} ${ARRAY_DSK_MODEL[$nc]} ${ARRAY_DSK_LABEL[$nc]}!"
		((nc++))
	done
}

sh_write() {
	local i=0
	local l=0
	local xtemp
	local sectorsize

	xtemp="$(mktemp)"
	sectorsize=$(fdisk -s "$isofile")
	(while [[ $l -lt "$sectorsize" ]]; do
		echo "dd if=$isofile of=$sd bs=8192000 count=1 skip=$i seek=$i oflag=direct" >"$xtemp"
		if ! dd if="$isofile" of="${sd}" bs=8192000 count=1 skip="$i" seek="$i" oflag=direct >>"$xtemp" 2>&1; then
			break
		fi
		rm "$xtemp"
		i=$(("$i" + 1))
		l=$(("$l" + 8000))
		q=$(("$l" * 100 / "$sectorsize"))
		echo -e "$q \n#""${MSG[10]}"" : $q %"
	done) | zenity \
		--progress \
		--width 650 \
		--auto-close \
		--title "${MSG[11]}: ${isofile}"
	result=$?
	if [ "$result" -eq 1 ]; then
		zenity \
			--warning \
			--text="${MSG[14]}" \
			--title="${MSG[15]}"
		rm -f "$xtemp"
		sh_main
	fi

	if [[ -f "$xtemp" ]]; then
		zenity \
			--error \
			--text="$(cat "$xtemp")"
		rm "$xtemp"
		sh_main
	else
		sync
		zenity \
			--info \
			--text="${MSG[12]}" \
			--title="${MSG[13]}"
		exit 0
	fi
}

sh_main() {
	sh_choosedisk
	while true; do
		cmdmain=(
			"${comargs[@]}"
			--text="<b><big><big>$(gettext "Propriedades do Dispositivo")</big></big></b>\n"
			--button="yad-refresh:3"
			--button="yad-close:1"
			--button="yad-save!Gravar:2"
			--form
			--columns=1
			--field="$(gettext "Dispositivo:")":CB "${USBDSK[*]}"
			--field="$(gettext "Arquivo ISO:")":FL "$ISO_START_DIR"
			--file-filter="$(gettext "Imagens ISO") | *.iso"
		)
		result=$(yad "${cmdmain[@]}")
		nchoice=$?

		case $nchoice in
		3)
			sh_choosedisk
			continue
			;;
		1 | 252) exit 0 ;;
		2)
			sd=$(echo "${result}" | cut -d"|" -f1 | awk '{print $1}')
			isofile=$(echo "${result}" | cut -d"|" -f2)

			export sd
			export isofile

			if [[ -z "$isofile" ]]; then
				yad_message slide_$(gettext "Selecione a ISO para copiar")
				continue
			fi
			if [[ -z "$sd" ]]; then
				yad_message "$(gettext "Selecione o seu USB drive")"
				continue
			fi
			sh_write
			;;
		esac
	done
}

check_deps
sh_initvars
sh_main
