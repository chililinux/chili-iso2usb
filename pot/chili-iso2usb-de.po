#: usr/bin/chili-iso2usb:46
#, sh-printf-format
msgid "ERRO: não encontrei o comando '%s'"
msgstr "FEHLER: Ich habe den Befehl „%s“ nicht gefunden."

#: usr/bin/chili-iso2usb:50
msgid "---IMPOSSÍVEL CONTINUAR---"
msgstr "---WEITERFÜHREN UNMÖGLICH---"

#: usr/bin/chili-iso2usb:51
msgid "Esse script necessita dos comandos listados acima"
msgstr "Dieses Skript erfordert die oben aufgeführten Befehle"

#: usr/bin/chili-iso2usb:52
#, sh-format
msgid "Instale-os e/ou verifique se estão no seu $PATH"
msgstr "Installieren Sie sie und/oder prüfen Sie, ob sie auf Ihrem $PATH vorhanden sind"

#: usr/bin/chili-iso2usb:60
msgid "Fechar"
msgstr "Zum Schließen"

#: usr/bin/chili-iso2usb:132
msgid "Progresso:"
msgstr "Fortschritt:"

#: usr/bin/chili-iso2usb:139
msgid "Copiar de"
msgstr "Kopieren von"

#: usr/bin/chili-iso2usb:139
msgid "Gravando a imagem ISO no dispositivo..."
msgstr "Brennen des ISO-Images auf das Gerät..."

#: usr/bin/chili-iso2usb:142
msgid "Problema na ferramenta. Contactar o autor."
msgstr "Werkzeugproblem. Kontaktieren Sie den Autor."

#: usr/bin/chili-iso2usb:146
msgid "Você já pode remover o seu USB drive."
msgstr "Sie können jetzt Ihr USB-Laufwerk entfernen."

#: usr/bin/chili-iso2usb:146
msgid "Fim de copiar"
msgstr "Ende des Kopiervorgangs"

#: usr/bin/chili-iso2usb:156
msgid "Propriedades do Drive"
msgstr "Laufwerkseigenschaften"

#: usr/bin/chili-iso2usb:162
msgid "Dispositivo:"
msgstr "Gerät:"

#: usr/bin/chili-iso2usb:163
msgid "Arquivo ISO:"
msgstr "ISO-Datei:"

#: usr/bin/chili-iso2usb:164
msgid "Imagens ISO"
msgstr "ISO-Bilder"

#: usr/bin/chili-iso2usb:183
msgid "Selecione a ISO para copiar"
msgstr "Wählen Sie die zu kopierende ISO aus"

#: usr/bin/chili-iso2usb:187
msgid "Selecione o seu USB drive"
msgstr "Wählen Sie Ihr USB-Laufwerk aus"
