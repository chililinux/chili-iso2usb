#: usr/bin/chili-iso2usb:46
#, sh-printf-format
msgid "ERRO: não encontrei o comando '%s'"
msgstr "오류: '%s' 명령을 찾지 못했습니다."

#: usr/bin/chili-iso2usb:50
msgid "---IMPOSSÍVEL CONTINUAR---"
msgstr "---계속 불가능---"

#: usr/bin/chili-iso2usb:51
msgid "Esse script necessita dos comandos listados acima"
msgstr "이 스크립트에는 위에 나열된 명령이 필요합니다."

#: usr/bin/chili-iso2usb:52
#, sh-format
msgid "Instale-os e/ou verifique se estão no seu $PATH"
msgstr "설치하거나 $PATH에 있는지 확인하세요."

#: usr/bin/chili-iso2usb:60
msgid "Fechar"
msgstr "닫으려면"

#: usr/bin/chili-iso2usb:132
msgid "Progresso:"
msgstr "진전:"

#: usr/bin/chili-iso2usb:139
msgid "Copiar de"
msgstr "복사 원본"

#: usr/bin/chili-iso2usb:139
msgid "Gravando a imagem ISO no dispositivo..."
msgstr "ISO 이미지를 장치에 굽는 중..."

